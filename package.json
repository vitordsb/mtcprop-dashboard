{
  "name": "mtcprop-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node ./scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:reset": "SEED_MODE=reset tsx prisma/seed.ts",
    "db:bootstrap": "pnpm db:generate && pnpm db:migrate:deploy && pnpm db:seed",
    "db:bootstrap:reset": "pnpm db:generate && pnpm db:migrate:deploy && pnpm db:seed:reset",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "dotenv": "^16.6.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "prisma": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
