generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  SUPPORT
  ANALYST
}

enum StudentStage {
  ONBOARDING
  TRAINING
  EVALUATION
  SIMULATOR
  LIVE_DESK
}

enum TraderSourceOrigin {
  CHALLENGE
  FAST
  LIVE_DESK
}

enum ProductKind {
  COURSE
  PROP_PLAN
  MENTORSHIP
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

enum AccessStatus {
  PENDING
  ACTIVE
  BLOCKED
  EXPIRED
}

model AdminUser {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         UserRole     @default(ADMIN)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  auditEvents  AuditEvent[]
}

model Student {
  id                      String             @id @default(cuid())
  name                    String
  email                   String             @unique
  phone                   String?
  stage                   StudentStage       @default(ONBOARDING)
  mentorName              String?
  workbookSlug            String?            @unique
  isActive                Boolean            @default(true)
  workbookOrigin          TraderSourceOrigin?
  workbookSourceSheets    Json?
  workbookHistoryCount    Int                @default(1)
  workbookSalesCount      Int                @default(0)
  workbookRestartUsed     Boolean            @default(false)
  workbookHasLiveDesk     Boolean            @default(false)
  workbookNextMonthlyDueAt DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  enrollments             Enrollment[]
  accessGrants            AccessGrant[]
}

model Product {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  kind         ProductKind  @default(COURSE)
  price        Decimal      @db.Decimal(10, 2)
  maxContracts Int?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  enrollments  Enrollment[]
}

model Enrollment {
  id           String           @id @default(cuid())
  studentId    String
  productId    String
  status       EnrollmentStatus @default(PENDING)
  startedAt    DateTime?
  endsAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  product      Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  accessGrants AccessGrant[]

  @@index([studentId, status])
  @@index([productId])
}

model AccessGrant {
  id           String       @id @default(cuid())
  studentId    String
  enrollmentId String?
  moduleKey    String
  status       AccessStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment   Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([studentId, status])
  @@index([moduleKey])
}

model AuditEvent {
  id          String    @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String
  payload     Json?
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([adminUserId])
}
