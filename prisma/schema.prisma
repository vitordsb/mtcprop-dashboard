generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  SUPPORT
  ANALYST
}

enum StudentStage {
  ONBOARDING
  TRAINING
  EVALUATION
  SIMULATOR
  LIVE_DESK
}

enum TraderSourceOrigin {
  CHALLENGE
  FAST
  LIVE_DESK
}

enum ProductKind {
  COURSE
  PROP_PLAN
  MENTORSHIP
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

enum AccessStatus {
  PENDING
  ACTIVE
  BLOCKED
  EXPIRED
}

enum ApprovalStatus {
  PENDENTE
  APROVADO
  REPROVADO
}

enum SolicitacaoType {
  APROVACAO
  LIBERACAO_PLATAFORMA
  MIGRACAO_MESA_REAL
  RESET_GRATUITO
  REPASSE
}

enum SolicitacaoStatus {
  PENDENTE
  APROVADA
  REJEITADA
  CONCLUIDA
}

model AdminUser {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(ADMIN)
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  auditEvents         AuditEvent[]
  passwordResetTokens PasswordResetToken[]
}

model Student {
  id                       String              @id @default(cuid())
  name                     String
  email                    String              @unique
  supabaseUserId           String?             @unique
  phone                    String?
  stage                    StudentStage        @default(ONBOARDING)
  mentorName               String?
  workbookSlug             String?             @unique
  isActive                 Boolean             @default(true)
  workbookOrigin           TraderSourceOrigin?
  workbookSourceSheets     Json?
  workbookHistoryCount     Int                 @default(1)
  workbookSalesCount       Int                 @default(0)
  workbookRestartUsed      Boolean             @default(false)
  workbookHasLiveDesk      Boolean             @default(false)
  workbookNextMonthlyDueAt DateTime?
  nelogicaDocument         String?
  nelogicaActivationCode   String?
  nelogicaContaID          String?
  nelogicaProduct          String?             @default("pro")
  nelogicaStatus           String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  enrollments              Enrollment[]
  accessGrants             AccessGrant[]
  solicitacoes             Solicitacao[]
}

model Product {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  kind         ProductKind  @default(COURSE)
  price        Decimal      @db.Decimal(10, 2)
  maxContracts Int?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  enrollments  Enrollment[]
}

model Enrollment {
  id                    String           @id @default(cuid())
  studentId             String
  productId             String
  status                EnrollmentStatus @default(PENDING)
  startedAt             DateTime?
  endsAt                DateTime?
  guruSubscriptionId    String?
  guruSubscriptionCode  String?
  guruStatus            String?
  guruProductId         String?
  guruProductName       String?
  guruContactId         String?
  guruLastWebhookAt     DateTime?
  approvalStatus        ApprovalStatus   @default(PENDENTE)
  approvalDecidedAt     DateTime?
  approvalDecidedById   String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  student               Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  product               Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  accessGrants          AccessGrant[]

  @@index([studentId, status])
  @@index([productId])
  @@index([guruSubscriptionId])
  @@index([approvalStatus])
}

model Solicitacao {
  id           String            @id @default(cuid())
  studentId    String
  type         SolicitacaoType
  status       SolicitacaoStatus @default(PENDENTE)
  /// Conta master da Nelogica relacionada (opcional, ajuda no roteamento das aprovações).
  masterAccount String?
  /// CPF/CNPJ vindo da Nelogica (snapshot no momento da solicitação).
  document     String?
  /// Observação livre do trader ao criar a solicitação.
  message      String?
  /// Resposta/observação do admin ao aprovar/rejeitar.
  adminNotes   String?
  decidedAt    DateTime?
  decidedById  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([status, type])
  @@index([studentId])
  @@index([createdAt])
}

model AccessGrant {
  id           String       @id @default(cuid())
  studentId    String
  enrollmentId String?
  moduleKey    String
  status       AccessStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment   Enrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([studentId, status])
  @@index([moduleKey])
}

model GuruTransactionSnapshot {
  id                   String    @id @default(cuid())
  guruTransactionId    String    @unique
  guruTransactionCode  String?
  guruContactId        String?
  contactName          String
  contactEmail         String?
  contactDocument      String?
  productName          String
  productOfferName     String?
  status               String?
  currency             String?
  amount               Decimal?  @db.Decimal(10, 2)
  orderedAt            DateTime?
  confirmedAt          DateTime?
  canceledAt           DateTime?
  guruSubscriptionId   String?
  guruSubscriptionCode String?
  rawPayload           Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([guruContactId])
  @@index([contactEmail])
  @@index([contactDocument])
  @@index([orderedAt])
  @@index([confirmedAt])
  @@index([canceledAt])
}

model AuditEvent {
  id          String    @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String
  payload     Json?
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([adminUserId])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, expiresAt])
  @@index([adminUserId, usedAt])
}
